# Soulseek credentials (required)
SLSK_USERNAME=your_soulseek_username
SLSK_PASSWORD=your_soulseek_password

# Spotify API credentials (required for Spotify playlist URLs)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Download settings
SLDL_DOWNLOAD_PATH=./downloads
SLDL_PREFERRED_FORMAT=mp3
SLDL_MIN_BITRATE=200
