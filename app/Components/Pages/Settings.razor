@page "/settings"
@using SldlWeb.Models
@using SldlWeb.Services
@inject SettingsService SettingsService
@rendermode InteractiveServer

<PageTitle>Settings</PageTitle>

<a href="/" class="back-link">&larr; Back</a>

<section class="settings-page">
    <h2>Settings</h2>

    @if (saved)
    {
        <div class="settings-saved">Settings saved.</div>
    }

    <div class="settings-group">
        <h3>Soulseek</h3>
        <div class="settings-field">
            <label for="slsk-user">Username</label>
            <input id="slsk-user" type="text" @bind="model.SoulseekUsername" placeholder="Soulseek username" />
        </div>
        <div class="settings-field">
            <label for="slsk-pass">Password</label>
            <input id="slsk-pass" type="password" @bind="model.SoulseekPassword" placeholder="Soulseek password" />
        </div>
    </div>

    <div class="settings-group">
        <h3>Spotify <span class="muted">(optional)</span></h3>
        <div class="settings-field">
            <label for="spotify-id">Client ID</label>
            <input id="spotify-id" type="text" @bind="model.SpotifyClientId" placeholder="Spotify Client ID" />
        </div>
        <div class="settings-field">
            <label for="spotify-secret">Client Secret</label>
            <input id="spotify-secret" type="password" @bind="model.SpotifyClientSecret" placeholder="Spotify Client Secret" />
        </div>
    </div>

    <div class="settings-group">
        <h3>Downloads</h3>
        <div class="settings-field">
            <label for="dl-path">Download Path</label>
            <input id="dl-path" type="text" @bind="model.DownloadPath" placeholder="./downloads" />
        </div>
        <div class="settings-field">
            <label for="pref-format">Preferred Format</label>
            <select id="pref-format" @bind="model.PreferredFormat">
                <option value="mp3">mp3</option>
                <option value="flac">flac</option>
                <option value="ogg">ogg</option>
                <option value="m4a">m4a</option>
                <option value="opus">opus</option>
                <option value="wav">wav</option>
            </select>
        </div>
        <div class="settings-field">
            <label for="min-bitrate">Min Bitrate (kbps)</label>
            <input id="min-bitrate" type="number" @bind="model.MinBitrate" placeholder="200" />
        </div>
    </div>

    <div class="settings-group">
        <h3>Default Extra Arguments <span class="muted">(applied to every download)</span></h3>
        @if (model.DefaultExtraArgs.Any())
        {
            <div class="extra-args-list settings-extra-args-list">
                @for (int i = 0; i < model.DefaultExtraArgs.Count; i++)
                {
                    var idx = i;
                    var arg = model.DefaultExtraArgs[idx];
                    <div class="extra-arg-row">
                        <span class="extra-arg-flag">@arg.Flag</span>
                        @if (!string.IsNullOrEmpty(arg.Value))
                        {
                            <span class="extra-arg-value">@arg.Value</span>
                        }
                        <button class="btn-remove-arg" @onclick="() => RemoveDefaultArg(idx)" title="Remove">×</button>
                    </div>
                }
            </div>
        }
        <div class="extra-args-add-row">
            <select class="extra-args-select" @bind="selectedArgFlag">
                <option value="">— pick argument —</option>
                @foreach (var known in KnownArg.All)
                {
                    <option value="@known.Flag">@known.Label (@known.Flag)</option>
                }
            </select>
            @if (SelectedKnown is { Type: not "flag" })
            {
                <input class="extra-args-value-input"
                       type="@(SelectedKnown.Type == "number" ? "number" : "text")"
                       placeholder="@SelectedKnown.Placeholder"
                       @bind="pendingArgValue" />
            }
            <button class="btn-add-arg" @onclick="AddDefaultArg" disabled="@string.IsNullOrEmpty(selectedArgFlag)">+</button>
        </div>
    </div>

    <button class="btn-save" @onclick="Save">Save</button>
</section>

@code {
    private AppSettings model = new();
    private bool saved;

    private string selectedArgFlag = "";
    private string pendingArgValue = "";

    private KnownArg? SelectedKnown =>
        KnownArg.All.FirstOrDefault(a => a.Flag == selectedArgFlag);

    protected override void OnInitialized()
    {
        model = SettingsService.Get();
    }

    private void AddDefaultArg()
    {
        if (string.IsNullOrEmpty(selectedArgFlag)) return;
        var known = SelectedKnown;
        if (known is null) return;

        model.DefaultExtraArgs.Add(new ExtraArg
        {
            Flag = selectedArgFlag,
            Value = known.Type == "flag" ? "" : pendingArgValue.Trim()
        });

        selectedArgFlag = "";
        pendingArgValue = "";
    }

    private void RemoveDefaultArg(int index)
    {
        if (index >= 0 && index < model.DefaultExtraArgs.Count)
            model.DefaultExtraArgs.RemoveAt(index);
    }

    private void Save()
    {
        SettingsService.Update(model);
        saved = true;
    }
}
