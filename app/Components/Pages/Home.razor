@page "/"
@using SldlWeb.Models
@using SldlWeb.Services
@inject DownloadService DownloadService
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>sldl web</PageTitle>

<section class="input-section">
    <h2>Download Music</h2>
    <p class="subtitle">Paste a Spotify playlist URL, YouTube URL, search query, or CSV track list.</p>

    <div class="input-form">
        <textarea @bind="inputText" @bind:event="oninput"
                  placeholder="https://open.spotify.com/playlist/...&#10;or: Artist - Title&#10;or CSV with Artist,Title columns"
                  rows="4"
                  class="input-textarea"></textarea>
        <div class="form-bottom-row">
            <div class="form-options">
                <label class="toggle-label">
                    <input type="checkbox" @bind="albumMode" />
                    <span>Album</span>
                </label>
                @if (profiles.Count > 0)
                {
                    <div class="form-options-divider"></div>
                    <div class="profile-dropdown @(profileOpen ? "open" : "")">
                        <button type="button" class="profile-trigger" @onclick="ToggleProfile">
                            <span class="profile-label-text">Profile</span>
                            <span class="profile-value">@(string.IsNullOrEmpty(selectedProfile) ? "—" : selectedProfile)</span>
                        </button>
                        @if (profileOpen)
                        {
                            <div class="profile-menu">
                                <div class="profile-option @(string.IsNullOrEmpty(selectedProfile) ? "selected" : "")"
                                     @onclick='() => SelectProfile("")'>—</div>
                                @foreach (var p in profiles)
                                {
                                    <div class="profile-option @(selectedProfile == p ? "selected" : "")"
                                         @onclick="() => SelectProfile(p)">@p</div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
            <button @onclick="Submit" class="btn-submit">
                <span>Download</span>
            </button>
        </div>
    </div>
</section>

@if (jobs.Any())
{
    <section class="jobs-section">
        <h3>Jobs</h3>
        <div class="job-list">
            @foreach (var job in jobs)
            {
                <div class="job-card" @onclick="() => NavigateToJob(job.Id)">
                    <div class="job-header">
                        <span class="job-type badge-@job.InputType.ToLower()">@job.InputType</span>
                        <span class="job-status status-@job.Status.ToString().ToLower()">@job.Status</span>
                    </div>
                    <div class="job-input">@Truncate(job.Input, 80)</div>
                    <div class="job-meta">
                        @if (job.TotalTracks > 0)
                        {
                            <span>@job.DownloadedTracks / @job.TotalTracks tracks</span>
                        }
                        <span class="job-time">@job.CreatedAt.ToLocalTime().ToString("HH:mm")</span>
                    </div>
                    @if (job.Status == JobStatus.Running && job.TotalTracks > 0)
                    {
                        <div class="job-progress-bar">
                            <div class="job-progress-fill" style="width: @ProgressPercent(job)%"></div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>
}

@code {
    private string inputText = "";
    private bool albumMode;
    private string selectedProfile = "";
    private bool profileOpen = false;
    private bool isSubmitting;
    private DotNetObjectReference<Home>? _selfRef;
    private IReadOnlyList<string> profiles = [];
    private List<DownloadJob> jobs = new();
    private System.Threading.Timer? refreshTimer;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            profiles = DownloadService.GetAvailableProfiles();
            RefreshJobs();
            refreshTimer = new System.Threading.Timer(_ =>
            {
                _ = InvokeAsync(() =>
                {
                    RefreshJobs();
                    StateHasChanged();
                });
            }, null, 1000, 1000);
            StateHasChanged();
        }
    }

    private void RefreshJobs()
    {
        jobs = DownloadService.GetAllJobs().ToList();
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(inputText) && string.IsNullOrEmpty(selectedProfile)) return;
        isSubmitting = true;

        var job = DownloadService.CreateJob(inputText, albumMode, string.IsNullOrEmpty(selectedProfile) ? null : selectedProfile);
        inputText = "";
        isSubmitting = false;

        Nav.NavigateTo($"/job/{job.Id}");
    }

    private async Task ToggleProfile()
    {
        profileOpen = !profileOpen;
        if (profileOpen)
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("onClickOutside", _selfRef, ".profile-dropdown");
        }
    }

    [JSInvokable]
    public void CloseDropdown()
    {
        profileOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void SelectProfile(string p)
    {
        selectedProfile = p;
        profileOpen = false;
    }

    private void NavigateToJob(string id) => Nav.NavigateTo($"/job/{id}");

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "...";

    private static double ProgressPercent(DownloadJob job) =>
        job.TotalTracks > 0 ? Math.Round((double)job.DownloadedTracks / job.TotalTracks * 100, 1) : 0;

    public void Dispose()
    {
        refreshTimer?.Dispose();
        _selfRef?.Dispose();
    }
}
