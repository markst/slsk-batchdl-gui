@page "/job/{JobId}"
@using Microsoft.AspNetCore.SignalR.Client
@using SldlWeb.Models
@using SldlWeb.Services
@inject DownloadService DownloadService
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Job @JobId</PageTitle>

@if (job is not null && playingIndex is not null)
{
    <div class="audio-player-bar">
        <div class="audio-player-inner">
            <div class="audio-player-info">
                <span class="audio-player-title">@job.Tracks[playingIndex.Value].Title</span>
                <span class="audio-player-artist">@job.Tracks[playingIndex.Value].Artist</span>
            </div>
            <audio id="audioPlayer" controls autoplay
                   src="/api/jobs/@job.Id/tracks/@playingIndex/stream"
                   @onended="OnTrackEnded"></audio>
            <button class="btn-close-player" @onclick="StopPlayback" title="Close">&times;</button>
        </div>
    </div>
}

<a href="/" class="back-link">&larr; Back</a>

@if (job == null)
{
    <p class="muted">Job not found.</p>
}
else
{
    <section class="job-detail @(playingIndex is not null ? "has-player" : "")">
        <div class="job-detail-header">
            <div>
                <h2>
                    <span class="badge-@job.InputType.ToLower()">@job.InputType</span>
                    Job @job.Id
                </h2>
                <details class="job-input-details">
                    <summary class="muted">Show input</summary>
                    <pre class="muted job-input-full">@job.Input</pre>
                </details>
            </div>
            <div class="job-actions">
                <span class="job-status status-@job.Status.ToString().ToLower()">@job.Status</span>
                @if (job.Status == JobStatus.Running)
                {
                    <button @onclick="Cancel" class="btn-cancel">Cancel</button>
                }
                @if (job.Status is JobStatus.Completed or JobStatus.Failed or JobStatus.Cancelled)
                {
                    <button @onclick="Resume" class="btn-resume">Resume</button>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(job.Error))
        {
            <div class="error-banner">@job.Error</div>
        }

        @if (job.TotalTracks > 0)
        {
            <div class="overall-progress">
                <div class="progress-stats">
                    <span>@job.DownloadedTracks downloaded</span>
                    @if (job.FailedTracks > 0)
                    {
                        <span class="text-red">@job.FailedTracks failed</span>
                    }
                    <span class="muted">@job.TotalTracks total</span>
                </div>
                <div class="progress-bar-lg">
                    <div class="progress-fill-success" style="width: @SuccessPercent()%"></div>
                    <div class="progress-fill-fail" style="width: @FailPercent()%"></div>
                </div>
            </div>

            @if (job.AlbumMode)
            {
                @foreach (var album in AlbumGroups())
                {
                    var done = album.Count(t => t.State is "Downloaded" or "AlreadyExists");
                    var failed = album.Count(t => t.State == "Failed");
                    var total = album.Count();
                    var albumPct = total > 0 ? Math.Round((double)done / total * 100, 1) : 0;
                    var albumArtist = album.FirstOrDefault(t => !string.IsNullOrEmpty(t.Artist))?.Artist ?? "";

                    <div class="album-group">
                        <div class="album-header">
                            <div class="album-header-info">
                                <span class="album-name">@album.Key</span>
                                @if (!string.IsNullOrEmpty(albumArtist))
                                {
                                    <span class="album-artist">@albumArtist</span>
                                }
                            </div>
                            <div class="album-header-right">
                                <span class="album-stats">
                                    @done/@total
                                    @if (failed > 0) { <span class="text-red"> · @failed failed</span> }
                                </span>
                                <div class="album-progress-bar">
                                    <div class="album-progress-fill" style="width: @albumPct%"></div>
                                </div>
                            </div>
                        </div>
                        <div class="track-list">
                            @foreach (var (track, idx) in album.Select((t, i) => (t, i)))
                            {
                                @TrackRow(track, idx + 1)
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="track-list">
                    @foreach (var (track, idx) in job.Tracks.ToList().Select((t, i) => (t, i)))
                    {
                        @TrackRow(track, idx + 1)
                    }
                </div>
            }
        }
        else if (job.Status == JobStatus.Running)
        {
            <p class="muted">Loading track list...</p>
        }
    </section>
}


@code {
    [Parameter] public string JobId { get; set; } = "";

    private DownloadJob? job;
    private HubConnection? hubConnection;
    private System.Threading.Timer? refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        job = DownloadService.GetJob(JobId);

        // Poll job state every 500ms for model updates from the reporter
        refreshTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                job = DownloadService.GetJob(JobId);
                StateHasChanged();
            });
        }, null, 500, 500);

        // Also connect SignalR for immediate push updates
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/downloadHub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string, List<TrackInfo>>("TrackList", (jobId, tracks) =>
        {
            if (jobId == JobId) InvokeAsync(StateHasChanged);
        });

        hubConnection.On<string, string, string, long, long, double>("DownloadProgress", (jobId, artist, title, bytesTransferred, totalBytes, percent) =>
        {
            if (jobId == JobId) InvokeAsync(StateHasChanged);
        });

        hubConnection.On<string, string, string, string, string?, string?>("TrackStateChanged", (jobId, artist, title, state, failureReason, downloadPath) =>
        {
            if (jobId == JobId) InvokeAsync(StateHasChanged);
        });

        hubConnection.On<string, int, int, int>("OverallProgress", (jobId, downloaded, failed, total) =>
        {
            if (jobId == JobId) InvokeAsync(StateHasChanged);
        });

        hubConnection.On<string, int, int, int>("JobComplete", (jobId, downloaded, failed, total) =>
        {
            if (jobId == JobId)
            {
                job = DownloadService.GetJob(JobId);
                InvokeAsync(StateHasChanged);
            }
        });

        hubConnection.On<string, string>("JobUpdated", (jobId, status) =>
        {
            if (jobId == JobId)
            {
                job = DownloadService.GetJob(JobId);
                InvokeAsync(StateHasChanged);
            }
        });

        await hubConnection.StartAsync();
    }

    private void Cancel()
    {
        DownloadService.CancelJob(JobId);
        job = DownloadService.GetJob(JobId);
    }

    private void Resume()
    {
        DownloadService.ResumeJob(JobId);
        job = DownloadService.GetJob(JobId);
    }

    private void RetryTrack(int idx)
    {
        DownloadService.RetryTrack(JobId, idx);
    }

    private IEnumerable<IGrouping<string, TrackInfo>> AlbumGroups() =>
        job!.Tracks.ToList().GroupBy(t => string.IsNullOrEmpty(t.Album) ? "(Unknown Album)" : t.Album);

    private RenderFragment TrackRow(TrackInfo track, int number) => __builder =>
    {
        var idx = job!.Tracks.IndexOf(track);
        <div class="track-row state-@track.State.ToLower() @(playingIndex == idx ? "track-playing" : "")">
            <div class="track-index">
                @if (IsPlayable(track))
                {
                    <button class="btn-play" @onclick="() => Play(idx)" title="Play">
                        @if (playingIndex == idx)
                        {
                            <span>&#9646;&#9646;</span>
                        }
                        else
                        {
                            <span>&#9654;</span>
                        }
                    </button>
                }
                else
                {
                    @number
                }
            </div>
            <div class="track-info">
                <div class="track-title">@track.Title</div>
                <div class="track-artist">@track.Artist</div>
            </div>
            <div class="track-meta">
                @if (!string.IsNullOrEmpty(track.Username))
                {
                    <span class="track-user">@track.Username</span>
                }
                @if (track.Extension != null)
                {
                    <span class="track-ext">.@track.Extension</span>
                }
                @if (track.BitRate > 0)
                {
                    <span class="track-bitrate">@(track.BitRate)kbps</span>
                }
            </div>
            <div class="track-state">
                @if (track.State == "Downloading" && track.TotalBytes > 0)
                {
                    <div class="track-progress-bar">
                        <div class="track-progress-fill" style="width: @track.Progress%"></div>
                    </div>
                    <span class="track-percent">@track.Progress.ToString("F0")%</span>
                }
                else if (track.State == "Failed")
                {
                    <span class="state-label">@FormatState(track)</span>
                    <button class="btn-retry" @onclick="() => RetryTrack(idx)" title="Retry">&#8635;</button>
                }
                else
                {
                    <span class="state-label">@FormatState(track)</span>
                }
            </div>
        </div>;
    };

    private double SuccessPercent() =>
        job != null && job.TotalTracks > 0 ? Math.Round((double)job.DownloadedTracks / job.TotalTracks * 100, 1) : 0;

    private double FailPercent() =>
        job != null && job.TotalTracks > 0 ? Math.Round((double)job.FailedTracks / job.TotalTracks * 100, 1) : 0;

    private int? playingIndex;

    private static bool IsPlayable(TrackInfo track) =>
        (track.State is "Downloaded" or "AlreadyExists") && !string.IsNullOrEmpty(track.DownloadPath);

    private void Play(int idx)
    {
        playingIndex = playingIndex == idx ? null : idx;
    }

    private void StopPlayback()
    {
        playingIndex = null;
    }

    private void OnTrackEnded()
    {
        // Auto-advance to next playable track
        if (job is null || playingIndex is null) return;
        for (var i = playingIndex.Value + 1; i < job.Tracks.Count; i++)
        {
            if (IsPlayable(job.Tracks[i]))
            {
                playingIndex = i;
                return;
            }
        }
        playingIndex = null;
    }

    private static string FormatState(TrackInfo track) => track.State switch
    {
        "Initial" => "",
        "Searching" => "Searching...",
        "Found" => "Found",
        "Downloading" => "Downloading...",
        "Downloaded" => "Done",
        "AlreadyExists" => "Exists",
        "Failed" => track.FailureReason ?? "Failed",
        _ => track.State
    };

    public async ValueTask DisposeAsync()
    {
        refreshTimer?.Dispose();
        if (hubConnection is not null)
            await hubConnection.DisposeAsync();
    }
}
