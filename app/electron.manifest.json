{
  "executable": "SldlWeb",
  "splashscreen": {
    "imageFile": ""
  },
  "name": "sldlr",
  "author": "",
  "singleInstance": true,
  "environment": "Production",
  "browserWindow": {
    "width": 1200,
    "height": 800,
    "minWidth": 800,
    "minHeight": 600,
    "title": "sldlr",
    "webPreferences": {
      "nodeIntegration": false,
      "contextIsolation": true
    }
  },
  "loadingWindow": {
    "width": 300,
    "height": 300,
    "isAlwaysOnTop": true
  },
  "build": {
    "appId": "com.sldlr.app",
    "productName": "sldlr",
    "buildVersion": "0.1.0",
    "extraResources": [
      {
        "from": "./bin",
        "to": "bin",
        "filter": ["**/*"]
      }
    ]
  },
  "forge": {
    "electronPackagerConfig": {
      "name": "sldlr"
    },
    "electronWinstallerConfig": {
      "name": "sldlr"
    },
    "electronDebuilderConfig": {
      "name": "sldlr"
    },
    "electronInstallerDMG": {
      "name": "sldlr"
    },
    "makers": [
      {
        "name": "@electron-forge/maker-squirrel",
        "platforms": [
          "win32"
        ]
      },
      {
        "name": "@electron-forge/maker-dmg",
        "platforms": [
          "darwin"
        ]
      },
      {
        "name": "@electron-forge/maker-zip",
        "platforms": [
          "linux",
          "darwin",
          "win32"
        ]
      }
    ]
  }
}
